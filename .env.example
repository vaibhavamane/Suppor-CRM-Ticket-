# Database Connection string (e.g. Supabase Transaction Pooler URI)
# Use your actual password in place of YOUR_DB_PASSWORD
DATABASE_URL="postgresql://postgres.yourprojectid:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Bloom Filter Settings
BLOOM_CAPACITY=10000
BLOOM_ERROR_RATE=0.001
